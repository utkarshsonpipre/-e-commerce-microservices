# ─────────────────────────────────────────────────────────────
#  Shared infrastructure
# ─────────────────────────────────────────────────────────────
# MongoDB (one container, one logical DB per service)
MONGO_HOST=mongodb
MONGO_PORT=27017

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=ecommerce

# JWT — shared signing secret used by auth (sign) and every service (verify).
# In production prefer an asymmetric keypair; a shared secret is fine for the demo.
JWT_SECRET=super-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Shared secret guarding internal service-to-service REST endpoints
INTERNAL_API_KEY=dev-internal-key

# Internal service URLs (used for synchronous REST calls between services)
AUTH_SERVICE_URL=http://auth:3001
CATALOG_SERVICE_URL=http://product-catalog:3002
ORDERS_SERVICE_URL=http://orders:3003
PAYMENTS_SERVICE_URL=http://payments:3004
NOTIFICATIONS_SERVICE_URL=http://notifications:3005

# ─────────────────────────────────────────────────────────────
#  Stripe (payments service)
# ─────────────────────────────────────────────────────────────
# Use Stripe TEST keys. Webhook secret comes from `stripe listen` or the dashboard.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Where Stripe Checkout redirects the customer back to:
STRIPE_SUCCESS_URL=http://localhost:8080/checkout/success
STRIPE_CANCEL_URL=http://localhost:8080/checkout/cancel

# ─────────────────────────────────────────────────────────────
#  Notifications (dev mailer)
# ─────────────────────────────────────────────────────────────
# 'log' just prints emails to stdout. 'smtp' uses the SMTP_* vars (e.g. Mailhog).
MAIL_TRANSPORT=log
SMTP_HOST=mailhog
SMTP_PORT=1025
MAIL_FROM=no-reply@shop.example
